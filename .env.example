# ── AI Provider Selection ────────────────────────────────────
# Choose which AI backend to use.
# Options: ollama (local, recommended), groq, gemini, openai
AI_PROVIDER=ollama

# ── Ollama Configuration (recommended — free, private, no rate limits) ────
# Run Ollama locally with Docker: docker run -d --name ollama -p 11435:11434 ollama/ollama
# Then pull a model: docker exec ollama ollama pull hermes3:latest
OLLAMA_MODEL=hermes3:latest
OLLAMA_BASE_URL=http://localhost:11435/v1
OLLAMA_ENABLE_TOOLS=true

# ── Groq Configuration ───────────────────────────────────────
# Get your free API key from: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=groq/compound-mini
GROQ_MAX_TOKENS=8192
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ── Google Gemini Configuration ──────────────────────────────
# Get your free Gemini API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=8192

# ── OpenAI Configuration ────────────────────────────────────
# Your OpenAI API key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2048

# ── Qualys VMDR API Configuration ────────────────────────────
# Get credentials from: Qualys Console → Administration → API
QUALYS_USERNAME=
QUALYS_PASSWORD=
# Qualys API base URL for your platform:
# US-1: https://qualysapi.qualys.com
# US-2: https://qualysapi.qg2.apps.qualys.com
# US-3: https://qualysapi.qg3.apps.qualys.com
# EU-1: https://qualysapi.qualys.eu
# EU-2: https://qualysapi.qg2.apps.qualys.eu
# India: https://qualysapi.qg1.apps.qualys.in
QUALYS_BASE_URL=https://qualysapi.qualys.com
# Gateway URL (for JWT auth):
# US-1: https://gateway.qg1.apps.qualys.com
# US-2: https://gateway.qg2.apps.qualys.com
# US-3: https://gateway.qg3.apps.qualys.com
# EU-1: https://gateway.qg1.apps.qualys.eu
# EU-2: https://gateway.qg2.apps.qualys.eu
# India: https://gateway.qg1.apps.qualys.in
QUALYS_GATEWAY_URL=https://gateway.qg1.apps.qualys.com

# ── Application Server Configuration ────────────────────────
PORT=3000
NODE_ENV=development

# ── Session Configuration ────────────────────────────────────
# Generate a secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
RATE_LIMIT_DESTRUCTIVE_MAX=10

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=dev

# ── Confirmation TTL ─────────────────────────────────────────
CONFIRMATION_TTL_MS=300000
